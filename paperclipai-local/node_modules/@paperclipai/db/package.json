{
  "name": "@paperclipai/db",
  "version": "2026.403.0",
  "license": "MIT",
  "homepage": "https://github.com/paperclipai/paperclip",
  "bugs": {
    "url": "https://github.com/paperclipai/paperclip/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paperclipai/paperclip",
    "directory": "packages/db"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@paperclipai/shared": "2026.403.0",
    "drizzle-orm": "^0.38.4",
    "embedded-postgres": "^18.1.0-beta.16",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "scripts": {
    "check:migrations": "tsx src/check-migration-numbering.ts",
    "build": "pnpm run check:migrations && tsc && cp -r src/migrations dist/migrations",
    "clean": "rm -rf dist",
    "typecheck": "pnpm run check:migrations && tsc --noEmit",
    "generate": "pnpm run check:migrations && tsc -p tsconfig.json && drizzle-kit generate",
    "migrate": "pnpm run check:migrations && tsx src/migrate.ts",
    "seed": "tsx src/seed.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}